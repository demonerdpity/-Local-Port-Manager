{
  "name": "port-manager",
  "version": "1.0.0",
  "private": true,
  "description": "Electron + Vue desktop app for inspecting local ports and managing the owning process.",
  "main": "main.js",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:web\" \"npm:dev:electron\"",
    "dev:web": "vite",
    "dev:electron": "wait-on tcp:5173 && cross-env NODE_ENV=development electron .",
    "build": "vite build",
    "start": "npm run build && electron ."
  },
  "dependencies": {
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.1",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^34.2.0",
    "vite": "^6.2.1",
    "wait-on": "^8.0.3"
  }
}
